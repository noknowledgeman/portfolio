---
interface Props {
    title: string;
    description: string;
    repoUrl: string;
}

const { title, description, repoUrl } = Astro.props;
---

<article class="project-card">
    <div class="card-body">
        <h2>{title}</h2>
        <p>{description}</p>
        <a href={repoUrl} class="btn-ghost" target="_blank" rel="noopener">View Source</a>
    </div>
    <div class="card-canvas">
        <slot />
    </div>
</article>

<style>
    .project-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 2rem;
        background: var(--bg-2);
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    h2 {
        font-size: 1.4rem;
        color: var(--text);
    }

    p {
        color: var(--text-dim);
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .card-canvas {
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 4px;
        background: var(--bg-3);
    }

    .card-canvas :global(canvas) {
        max-width: 100%;
        height: auto;
    }

    @media (max-width: 700px) {
        .project-card {
            grid-template-columns: 1fr;
        }
        .card-canvas {
            order: -1;
        }
    }
</style>
