---
interface Props {
    title: string;
    description: string;
    href: string;
}

const { title, description, href } = Astro.props;
---

<a class="project-card" href={href}>
    <div class="card-body">
        <h2>{title}</h2>
        <p>{description}</p>
        <span class="btn-ghost">View Project →</span>
    </div>
    <div class="card-preview">
        <slot />
    </div>
</a>

<style>
    .project-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 2rem;
        background: var(--bg-2);
        text-decoration: none;
        transition: border-color 0.2s, background 0.2s;
    }

    .project-card:hover {
        border-color: var(--accent);
        background: var(--bg-3);
    }

    .card-preview {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-3);
        border-radius: 4px;
        overflow: hidden;
    }

    .card-preview :global(canvas) {
        max-width: 100%;
        height: auto;
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    h2 {
        font-size: 1.4rem;
        color: var(--text);
    }

    p {
        color: var(--text-dim);
        font-size: 0.9rem;
        line-height: 1.7;
    }

    @media (max-width: 700px) {
        .project-card {
            grid-template-columns: 1fr;
        }
    }
</style>
