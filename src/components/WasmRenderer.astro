---
interface Props {
    width?: number;
}

const { width = 800 } = Astro.props;
---

<canvas id="c" data-width={width}></canvas>
<script>
    /// <reference lib="dom" />

    const canvas = document.getElementById("c") as HTMLCanvasElement;
    const initWidth = Number(canvas.dataset.width);

    await new Promise<void>(resolve => {
        new IntersectionObserver(([entry], obs) => {
            if (!entry.isIntersecting) return;
            obs.disconnect();
            resolve();
        }, { threshold: 0.1 }).observe(canvas);
    });

    const module = await WebAssembly.instantiateStreaming(
        fetch(`${import.meta.env.BASE_URL}wasm/WasmRenderer.wasm`),
    );

    interface WasmExports extends WebAssembly.Exports {
        init: (width: number) => void;
        deinit: () => void;
        getBuffer: () => number;
        getWidth: () => number;
        getHeight: () => number;
        renderLine: () => void;
        memory: WebAssembly.Memory;
    }

    const { init, deinit, getBuffer, getWidth, getHeight, renderLine, memory } =
        module.instance.exports as WasmExports;

    init(initWidth);

    const width = getWidth();
    const height = getHeight();
    let currentLine = 0;

    const ptr = getBuffer();

    canvas.width = width;
    canvas.height = height;
    const ctx = canvas.getContext("2d")!;

    function renderNextLine() {
        if (currentLine >= height) return;

        renderLine();
        const pixels = new Uint8ClampedArray(
            memory.buffer,
            ptr + currentLine * width * 4,
            width * 4,
        );
        const imageData = new ImageData(pixels, width, 1);
        ctx.putImageData(imageData, 0, currentLine);

        currentLine++;
        requestAnimationFrame(renderNextLine);
    }

    requestAnimationFrame(renderNextLine);

    deinit();
</script>
