---
import Base from "../layouts/Base.astro";
---

<Base title="Home">
    <section class="hero">
        <div class="hero-inner">
            <p class="label mono">Systems / Security</p>
            <h1>Your Name</h1>
            <p class="tagline">Building fast, low-level systems and breaking things securely.</p>
            <div class="cta-row">
                <a href="/projects" class="btn-primary">View Projects</a>
                <a href="/about" class="btn-ghost">About Me</a>
            </div>
        </div>
        <div class="divider" />
    </section>
</Base>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 2rem;
        padding-top: 56px;
    }

    .hero-inner {
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
        padding: 6rem 0 4rem;
    }

    .label {
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--red);
        margin-bottom: 1.2rem;
    }

    h1 {
        font-size: clamp(2.8rem, 6vw, 5rem);
        font-weight: 600;
        line-height: 1.1;
        color: #e8f0f8;
        letter-spacing: -0.02em;
        margin-bottom: 1.2rem;
    }

    .tagline {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--text-dim);
        max-width: 520px;
        margin-bottom: 2.5rem;
        font-weight: 300;
    }

    .cta-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-primary {
        padding: 0.65rem 1.4rem;
        background: var(--red);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        border: 1px solid var(--red);
        transition: background 0.2s, border-color 0.2s;
    }

    .btn-primary:hover {
        background: #9a2828;
        border-color: #9a2828;
    }

    .btn-ghost {
        padding: 0.65rem 1.4rem;
        background: transparent;
        color: var(--text-dim);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        border: 1px solid var(--border);
        transition: color 0.2s, border-color 0.2s;
    }

    .btn-ghost:hover {
        color: var(--text);
        border-color: var(--text-dim);
    }

    .divider {
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
        height: 1px;
        background: linear-gradient(to right, var(--red-dim), transparent);
    }

    .mono {
        font-family: var(--font-mono);
    }
</style>
